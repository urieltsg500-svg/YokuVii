local InstantRespawnGroup = Tabs.Teleport:AddRightGroupbox("Instant Respawn", "map-pin")

local respawnArgs = {5917762, 5, 5, 13, 13405801, 12950139, false}
local lastDeathPosition = nil
local respawnDebounce = false
local isRespawnTeleporting = false

local function attemptRespawn()
	if respawnDebounce then return end
	respawnDebounce = true

	local remoteInterface = ReplicatedStorage:FindFirstChild("remoteInterface")
	if not remoteInterface then
		respawnDebounce = false
		return
	end

	local characterFolder = remoteInterface:FindFirstChild("character")
	if not characterFolder then
		respawnDebounce = false
		return
	end

	local resetRemote = characterFolder:FindFirstChild("reset")
	if resetRemote then
		resetRemote:InvokeServer()
	end

	local respawnRemote = characterFolder:FindFirstChild("respawn")
	if respawnRemote then
		respawnRemote:InvokeServer(unpack(respawnArgs))
	end

	respawnDebounce = false
end

local function respawnTeleport(cframe)
	isRespawnTeleporting = true
	local maxWaitTime = 0.5
	local startTime = tick()

	while not LocalPlayer.Character and tick() - startTime < maxWaitTime do
		task.wait(0.2)
	end

	if not LocalPlayer.Character then
		isRespawnTeleporting = false
		return
	end

	local humanoidRootPart = LocalPlayer.Character:FindFirstChild("HumanoidRootPart")
	local waitTime = 0

	while not humanoidRootPart and waitTime < maxWaitTime do
		task.wait(0.2)
		waitTime = waitTime + 0.01
		humanoidRootPart = LocalPlayer.Character:FindFirstChild("HumanoidRootPart")
	end

	if humanoidRootPart then
		humanoidRootPart.CFrame = cframe
	end
	isRespawnTeleporting = false
end

local function checkAndRespawn()
	if not Toggles.InstantRespawn.Value or isRespawnTeleporting then return end

	if not LocalPlayer.Character or not workspace:FindFirstChild(LocalPlayer.Name) then
		if lastDeathPosition then
			task.wait(0.00014)
			attemptRespawn()
			destroyAvatarGUI()
			task.wait(Options.TeleportDelaySlider.Value)
			respawnTeleport(CFrame.new(lastDeathPosition))
		end
	end
end

