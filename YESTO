local lastAdminCheck = 0
local function checkAdminPresence()
	if not Toggles.AdminNearby.Value then return end
	if tick() - lastAdminCheck < 2 then return end
	lastAdminCheck = tick()
	
	local myRoot = getRootPart()
	
	for _, player in ipairs(Players:GetPlayers()) do
		if player ~= LocalPlayer then
			if isAdmin(player) then
				local nearby = false
				local adminRoot = player.Character and player.Character:FindFirstChild("HumanoidRootPart")
				if myRoot and adminRoot then
					local dist = (myRoot.Position - adminRoot.Position).Magnitude
					if dist < 150 then
						nearby = true
