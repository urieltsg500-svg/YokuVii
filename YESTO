local espObjects = {}
local hasDrawing = (typeof(Drawing) ~= "nil")

local function clearESP()
	for _, obj in pairs(espObjects) do
		if typeof(obj) == "Instance" then
			obj:Destroy()
		elseif typeof(obj) == "table" then
			for _, child in pairs(obj) do
				if typeof(child) == "Instance" then
					child:Destroy()
				else
					pcall(function() child:Remove() end)
				end
			end
		end
	end
	table.clear(espObjects)
end

local function createESP(player)
	local character = player.Character
	if not character then
		return
	end
	local root = character:FindFirstChild("HumanoidRootPart")
	local hum = character:FindFirstChildOfClass("Humanoid")
	if not root or not hum then
		return
	end

	local box2d = nil
	if hasDrawing then
		box2d = Drawing.new("Square")
		box2d.Color = Color3.fromRGB(192, 192, 192)
		box2d.Thickness = 1.5
		box2d.Filled = false
		box2d.Visible = false
	end

	local billboard = Instance.new("BillboardGui")
	billboard.Size = UDim2.fromOffset(120, 40)
	billboard.AlwaysOnTop = true
	billboard.Adornee = root
	billboard.Parent = root

	local label = Instance.new("TextLabel")
	label.Size = UDim2.fromScale(1, 1)
	label.BackgroundTransparency = 1
	label.TextColor3 = Color3.new(1, 1, 1)
	label.TextStrokeTransparency = 0.5
	label.Font = Enum.Font.GothamBold
	label.TextSize = 14
	label.Parent = billboard

	local tracer = nil
	if hasDrawing then
		tracer = Drawing.new("Line")
		tracer.Color = Color3.fromRGB(192, 192, 192)
		tracer.Thickness = 1.5
		tracer.Transparency = 1
		tracer.Visible = false
	end

	espObjects[player] = { box2d, billboard, label, tracer }

	local function update()
		local myRoot = getRootPart()
		if not myRoot or not character.Parent then
			if tracer then tracer.Visible = false end
			if box2d then box2d.Visible = false end
			return
		end
		local dist = (root.Position - myRoot.Position).Magnitude
		local shouldShow = dist <= Options.ESPDistance.Value and Toggles.PlayerESP.Value
		if box2d then
			if shouldShow and Toggles.ShowBox and Toggles.ShowBox.Value then
				local screenPos, onScreen = workspace.CurrentCamera:WorldToViewportPoint(root.Position)
				if onScreen then
					local head = character:FindFirstChild("Head")
					local topPos = head and head.Position + Vector3.new(0, 0.5, 0) or root.Position + Vector3.new(0, 3, 0)
					local bottomPos = head and head.Position - Vector3.new(0, 6.5, 0) or root.Position - Vector3.new(0, 3.5, 0)
					
					local topCoords = workspace.CurrentCamera:WorldToViewportPoint(topPos)
					local bottomCoords = workspace.CurrentCamera:WorldToViewportPoint(bottomPos)
					
					local height = math.abs(topCoords.Y - bottomCoords.Y)
					local width = height * 0.6
					
					box2d.Position = Vector2.new(screenPos.X - width / 2, topCoords.Y)
					box2d.Size = Vector2.new(width, height)
					box2d.Visible = true
				else
					box2d.Visible = false
				end
			else
				box2d.Visible = false
			end
		end

		billboard.Enabled = shouldShow
		local text = player.Name
		if Toggles.ShowDistance.Value then
			text ..= string.format("\n%.0fm", dist)
		end
		if Toggles.ShowHealth.Value then
			text ..= string.format("\nHP: %.0f", hum.Health)
		end
		label.Text = text

		if tracer and Toggles.ShowTracers.Value then
			local pos, onScreen = workspace.CurrentCamera:WorldToViewportPoint(root.Position)
			if onScreen then
				tracer.From = Vector2.new(workspace.CurrentCamera.ViewportSize.X / 2, workspace.CurrentCamera.ViewportSize.Y)
				tracer.To = Vector2.new(pos.X, pos.Y)
				tracer.Visible = true
			else
				tracer.Visible = false
			end
		elseif tracer then
			tracer.Visible = false
		end
	end

	update()
	track("ESP_" .. player.Name, RunService.RenderStepped:Connect(update))
end

Toggles.PlayerESP:OnChanged(function()
