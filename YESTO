local function isAdmin(player)
	local success, rank = pcall(function()
		return player:GetRankInGroup(7312028)
	end)
	if success and rank and rank >= 10 then
		return true
	end
	
	local successRole, role = pcall(function()
		return player:GetRoleInGroup(7312028)
	end)
	if successRole and role then
		local lowerRole = role:lower()
		if lowerRole:find("admin") or lowerRole:find("mod") or lowerRole:find("dev") or lowerRole:find("staff") or lowerRole:find("creator") or lowerRole:find("owner") then
			return true
		end
	end
	
	local isRobloxStaff = false
	pcall(function()
		isRobloxStaff = player:IsInGroup(1200769)
	end)
	if isRobloxStaff then
		return true
	end
	
	return false
end

