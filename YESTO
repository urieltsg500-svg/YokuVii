local isDodging = false
local lastDodgeTime = 0
local dodgeCooldown = 0.3

local function isSwingAnimation(trackObj)
	local anim = trackObj.Animation
	local id = anim.AnimationId
	local name = anim.Name:lower()
	
	if name:find("idle") or name:find("walk") or name:find("run") or name:find("jump") or 
	   name:find("fall") or name:find("swim") or name:find("climb") or name:find("strafe") then
		return false
	end
	
	local movementIds = {
		["507766388"] = true, ["507777826"] = true, ["507767714"] = true,
		["507765000"] = true, ["507767968"] = true, ["507765644"] = true,
		["507784064"] = true, ["180426354"] = true, ["180415668"] = true,
		["180419271"] = true, ["180435571"] = true
	}
	for mId in pairs(movementIds) do
		if id:find(mId) then
			return false
		end
	end
	
	return true
end

local function performDodge(enemyRoot)
	if isDodging or tick() - lastDodgeTime < dodgeCooldown then return end
	isDodging = true
	lastDodgeTime = tick()
	
	local root = getRootPart()
	if not root then
		isDodging = false
		return
	end
	
	local originalCFrame = root.CFrame
	
	-- Teleport fast in the air (e.g. 18 studs up)
	root.CFrame = originalCFrame + Vector3.new(0, 18, 0)
	
	-- Wait a short time
	task.wait(0.3)
	
	-- Teleport back fast to original position
	if isAlive() and getRootPart() == root then
		root.CFrame = originalCFrame
	end
	isDodging = false
end

local function checkDodge()
	if not isAlive() or not Toggles.DodgeAttack.Value or isDodging then return end
	local root = getRootPart()
	if not root then return end
	
	for _, player in ipairs(Players:GetPlayers()) do
		if player ~= LocalPlayer and player.Character then
			local enemyRoot = player.Character:FindFirstChild("HumanoidRootPart")
			local enemyHum = player.Character:FindFirstChildOfClass("Humanoid")
			if enemyRoot and enemyHum and enemyHum.Health > 0 then
				local dist = (enemyRoot.Position - root.Position).Magnitude
				if dist <= 12 then
					local animator = enemyHum:FindFirstChild("Animator")
					if animator then
						for _, trackObj in ipairs(animator:GetPlayingAnimationTracks()) do
							if trackObj.TimePosition < 0.15 and trackObj.Speed > 0 then
								if isSwingAnimation(trackObj) then
									task.spawn(performDodge, enemyRoot)
									break
								end
							end
						end
					end
				end
			end
		end
	end
end

