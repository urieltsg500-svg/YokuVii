local cursorDrawings = {
	square = nil,
	circle = nil,
	xLine1 = nil,
	xLine2 = nil
}

local function initCursorDrawings()
	if not hasDrawing then return end
	
	if not cursorDrawings.square then
		cursorDrawings.square = Drawing.new("Square")
		cursorDrawings.square.Color = Color3.fromRGB(255, 255, 255)
		cursorDrawings.square.Filled = true
		cursorDrawings.square.Visible = false
	end
	if not cursorDrawings.circle then
		cursorDrawings.circle = Drawing.new("Circle")
		cursorDrawings.circle.Color = Color3.fromRGB(255, 255, 255)
		cursorDrawings.circle.Filled = false
		cursorDrawings.circle.Thickness = 1.5
		cursorDrawings.circle.Visible = false
	end
	if not cursorDrawings.xLine1 then
		cursorDrawings.xLine1 = Drawing.new("Line")
		cursorDrawings.xLine1.Color = Color3.fromRGB(255, 255, 255)
		cursorDrawings.xLine1.Thickness = 1.5
		cursorDrawings.xLine1.Visible = false
	end
	if not cursorDrawings.xLine2 then
		cursorDrawings.xLine2 = Drawing.new("Line")
		cursorDrawings.xLine2.Color = Color3.fromRGB(255, 255, 255)
		cursorDrawings.xLine2.Thickness = 1.5
		cursorDrawings.xLine2.Visible = false
	end
end

local function updateCursor()
	if not hasDrawing then return end
	initCursorDrawings()
	
	cursorDrawings.square.Visible = false
	cursorDrawings.circle.Visible = false
	cursorDrawings.xLine1.Visible = false
	cursorDrawings.xLine2.Visible = false
	
	if not Toggles.CustomCursorActive or not Toggles.CustomCursorActive.Value then return end
	
	local viewportSize = workspace.CurrentCamera.ViewportSize
	local center = Vector2.new(viewportSize.X / 2, viewportSize.Y / 2)
	local size = Options.CustomCursorSize.Value
	local cursorType = Options.CustomCursorType.Value
	
	if cursorType == "Tiny Square" then
		cursorDrawings.square.Size = Vector2.new(size, size)
		cursorDrawings.square.Position = center - Vector2.new(size / 2, size / 2)
		cursorDrawings.square.Visible = true
	elseif cursorType == "Circle" then
		cursorDrawings.circle.Radius = size / 2
		cursorDrawings.circle.Position = center
		cursorDrawings.circle.Visible = true
	elseif cursorType == "X" then
		local half = size / 2
		cursorDrawings.xLine1.From = center - Vector2.new(half, half)
		cursorDrawings.xLine1.To = center + Vector2.new(half, half)
		cursorDrawings.xLine1.Visible = true
		
		cursorDrawings.xLine2.From = center - Vector2.new(-half, half)
		cursorDrawings.xLine2.To = center + Vector2.new(-half, half)
		cursorDrawings.xLine2.Visible = true
	end
end

Toggles.CustomCursorActive:OnChanged(updateCursor)
Options.CustomCursorType:OnChanged(updateCursor)
Options.CustomCursorSize:OnChanged(updateCursor)

track("CursorUpdate", RunService.Heartbeat:Connect(updateCursor))


