local desyncConnections = {}
local desyncAnimTracks = {}
local fakeChar = nil
local originalCF = nil

local function startDesync()
	local RealChar = LocalPlayer.Character
	if not RealChar or not RealChar:FindFirstChild("HumanoidRootPart") then return end
	
	originalCF = RealChar.HumanoidRootPart.CFrame
	RealChar.Archivable = true
	
	local ok, err = pcall(function()
		fakeChar = RealChar:Clone()
	end)
	if not ok or not fakeChar then
		Library:Notify({ Title = "DESYNC", Description = "Failed to clone character: " .. tostring(err), Time = 3 })
		Toggles.DesyncToggle:SetValue(false)
		return
	end
	
	fakeChar.Name = "Desync_Clone"
	fakeChar.Parent = workspace
	
	RealChar.HumanoidRootPart.Anchored = true
	
	local fakeHum = fakeChar:FindFirstChild("Humanoid")
	local fakeRoot = fakeChar:FindFirstChild("HumanoidRootPart")
	
	if not fakeHum or not fakeRoot then
		fakeChar:Destroy()
		fakeChar = nil
		RealChar.HumanoidRootPart.Anchored = false
		Library:Notify({ Title = "DESYNC", Description = "Clone humanoid/rootpart missing.", Time = 3 })
		Toggles.DesyncToggle:SetValue(false)
		return
	end
	
	for _, v in pairs(fakeChar:GetDescendants()) do
		if v:IsA("LocalScript") or v:IsA("Script") then
			pcall(function() v:Destroy() end)
		end
		if v:IsA("BasePart") then
			v.CanCollide = (v.Name == "HumanoidRootPart")
			if v.Name == "HumanoidRootPart" then v.Transparency = 1 end
		end
	end

	local function LoadAnim(hum, id)
		local a = Instance.new("Animation")
		a.AnimationId = id
		local trackObj
		pcall(function()
			trackObj = hum:LoadAnimation(a)
		end)
		return trackObj
	end
	
	local OfficialIDs = {
		Idle  = "rbxassetid://507766388",
		Walk  = "rbxassetid://507777826",
		Run   = "rbxassetid://507767714",
		Jump  = "rbxassetid://507765000",
		Fall  = "rbxassetid://507767968",
	}

	desyncAnimTracks.Idle  = LoadAnim(fakeHum, OfficialIDs.Idle)
	desyncAnimTracks.Walk  = LoadAnim(fakeHum, OfficialIDs.Walk)
	desyncAnimTracks.Run   = LoadAnim(fakeHum, OfficialIDs.Run)
	desyncAnimTracks.Jump  = LoadAnim(fakeHum, OfficialIDs.Jump)
	desyncAnimTracks.Fall  = LoadAnim(fakeHum, OfficialIDs.Fall)

	local function StopAll()
		for _, trackObj in pairs(desyncAnimTracks) do
			if trackObj and trackObj.IsPlaying then
				pcall(function() trackObj:Stop(0.1) end)
			end
		end
	end

	workspace.CurrentCamera.CameraSubject = fakeHum
	if desyncAnimTracks.Idle then
		pcall(function() desyncAnimTracks.Idle:Play() end)
	end

	table.insert(desyncConnections, fakeHum.StateChanged:Connect(function(oldState, newState)
		if newState == Enum.HumanoidStateType.Jumping then
			StopAll()
			if desyncAnimTracks.Jump then pcall(function() desyncAnimTracks.Jump:Play() end) end
		elseif newState == Enum.HumanoidStateType.Freefall then
			StopAll()
			if desyncAnimTracks.Fall then pcall(function() desyncAnimTracks.Fall:Play() end) end
		elseif newState == Enum.HumanoidStateType.Landed then
			StopAll()
			if desyncAnimTracks.Idle then pcall(function() desyncAnimTracks.Idle:Play() end) end
		end
	end))

	local realHum = RealChar:FindFirstChildOfClass("Humanoid")
	if realHum then
		table.insert(desyncConnections, realHum.Died:Connect(function()
			Toggles.DesyncToggle:SetValue(false)
		end))
	end
	table.insert(desyncConnections, fakeHum.Died:Connect(function()
		Toggles.DesyncToggle:SetValue(false)
	end))

	local Controls = nil
	pcall(function()
		local PlayerModule = require(LocalPlayer:WaitForChild("PlayerScripts"):WaitForChild("PlayerModule"))
		Controls = PlayerModule:GetControls()
	end)

	table.insert(desyncConnections, RunService.RenderStepped:Connect(function()
		if not Toggles.DesyncToggle.Value or not fakeHum or not fakeRoot then return end
		
		for _, v in pairs(fakeChar:GetDescendants()) do
			if v:IsA("BasePart") then
				v.CanCollide = (v.Name == "HumanoidRootPart")
			end
		end
		
		local currentSpeed = 16
		if Toggles.SpeedHack and Toggles.SpeedHack.Value and Options.SpeedValue then
			currentSpeed = Options.SpeedValue.Value
		elseif RealChar:FindFirstChildOfClass("Humanoid") then
			currentSpeed = RealChar:FindFirstChildOfClass("Humanoid").WalkSpeed
		end
		fakeHum.WalkSpeed = currentSpeed
		
		local inputVector = Vector3.new(0, 0, 0)
		if Controls then
			inputVector = Controls:GetMoveVector()
		else
			if UserInputService:IsKeyDown(Enum.KeyCode.W) then inputVector = inputVector + Vector3.new(0, 0, -1) end
			if UserInputService:IsKeyDown(Enum.KeyCode.S) then inputVector = inputVector + Vector3.new(0, 0, 1) end
			if UserInputService:IsKeyDown(Enum.KeyCode.A) then inputVector = inputVector + Vector3.new(-1, 0, 0) end
			if UserInputService:IsKeyDown(Enum.KeyCode.D) then inputVector = inputVector + Vector3.new(1, 0, 0) end
		end
		
		local camCF = workspace.CurrentCamera.CFrame
		fakeHum.PlatformStand = false
		
		local finalDir = (camCF.RightVector * inputVector.X) + (camCF.LookVector * -inputVector.Z)
		finalDir = Vector3.new(finalDir.X, 0, finalDir.Z)
		
		local currentState = fakeHum:GetState()
		local isGrounded = (currentState == Enum.HumanoidStateType.Running or currentState == Enum.HumanoidStateType.RunningNoPhysics)
		
		if finalDir.Magnitude > 0 then
			fakeHum:Move(finalDir.Unit, false)
			if isGrounded then
				if desyncAnimTracks.Run and not desyncAnimTracks.Run.IsPlaying then
					StopAll()
					pcall(function() desyncAnimTracks.Run:Play(0.1) end)
				end
			end
		else
			fakeHum:Move(Vector3.new(0, 0, 0), false)
			if isGrounded then
				if desyncAnimTracks.Idle and not desyncAnimTracks.Idle.IsPlaying then
					StopAll()
					pcall(function() desyncAnimTracks.Idle:Play(0.1) end)
				end
			end
		end
	end))

	table.insert(desyncConnections, UserInputService.JumpRequest:Connect(function()
		if Toggles.DesyncToggle.Value and fakeHum and fakeHum:GetState() ~= Enum.HumanoidStateType.Freefall then
			fakeHum.Jump = true
		end
	end))
end

local function stopDesync()
	for _, conn in pairs(desyncConnections) do
		pcall(function() conn:Disconnect() end)
	end
	table.clear(desyncConnections)
	
	for _, trackObj in pairs(desyncAnimTracks) do
		if trackObj and trackObj.IsPlaying then
			pcall(function() trackObj:Stop() end)
		end
	end
	table.clear(desyncAnimTracks)
	
	if fakeChar then
		local lastCF
		pcall(function()
			lastCF = fakeChar:GetPrimaryPartCFrame()
		end)
		pcall(function() fakeChar:Destroy() end)
		fakeChar = nil
		
		local RealChar = LocalPlayer.Character
		if RealChar and RealChar:FindFirstChild("HumanoidRootPart") then
			RealChar.HumanoidRootPart.Anchored = false
			if lastCF then
				RealChar.HumanoidRootPart.CFrame = lastCF
			end
			local realHum = RealChar:FindFirstChildOfClass("Humanoid")
			if realHum then
				workspace.CurrentCamera.CameraSubject = realHum
			end
		end
	end
end

