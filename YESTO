local function getAngleFromPart(fromPart, toPart)
	local flat = ((toPart.Position - fromPart.Position) * Vector3.new(1, 0, 1)).Unit
	local look = fromPart.CFrame.LookVector * Vector3.new(1, 0, 1)
	return math.abs(look:Dot(flat) - 1) * 90
