-- Teleport Script Logic
local function resetAndTeleport(targetName)
	if not targetName or targetName == "" then
		Library:Notify({ Title = "Teleport", Description = "Please select a player first.", Time = 3 })
		return
	end
	
	local targetPlayer = Players:FindFirstChild(targetName)
	if not targetPlayer then
		Library:Notify({ Title = "Teleport", Description = "Target player not found in server.", Time = 3 })
		return
	end

	Library:Notify({ Title = "Teleport", Description = "Resetting and preparing teleport to " .. targetName .. "...", Time = 3 })

	-- Reset character
	pcall(function()
		game:GetService("ReplicatedStorage"):WaitForChild("remoteInterface"):WaitForChild("character"):WaitForChild("reset"):InvokeServer()
	end)

	-- Wait for new character to spawn
	local connection
	local spawned = false
	connection = LocalPlayer.CharacterAdded:Connect(function()
		spawned = true
		connection:Disconnect()
	end)
	
	-- Fallback check if it already spawned
	task.delay(5, function()
		if connection then
			connection:Disconnect()
		end
	end)
	
	local timeout = 0
	while not spawned and timeout < 50 do
		task.wait(0.1)
		timeout = timeout + 1
	end
	
	local char = LocalPlayer.Character
	local root = char and char:WaitForChild("HumanoidRootPart", 10)
	
	if root then
		task.wait(0.7) -- extra cushion wait to let player parts replicate fully
		
		-- Fetch target player again to make sure they didn't leave during reset
		local activeTarget = Players:FindFirstChild(targetName)
		local targetChar = activeTarget and activeTarget.Character
		local targetRoot = targetChar and targetChar:FindFirstChild("HumanoidRootPart")
		
		if targetRoot then
			root.CFrame = targetRoot.CFrame + Vector3.new(0, 3, 0)
			Library:Notify({ Title = "Teleport", Description = "Teleported successfully!", Time = 2 })
		else
			Library:Notify({ Title = "Teleport", Description = "Could not find target player's root part.", Time = 3 })
		end
	else
		Library:Notify({ Title = "Teleport", Description = "Failed to load character root part.", Time = 3 })
	end
end

local function updateTeleportPlayerList()
	local list = {}
	for _, player in ipairs(Players:GetPlayers()) do
		if player ~= LocalPlayer then
			table.insert(list, player.Name)
		end
	end
	pcall(function()
		Options.TeleportPlayerList:SetValues(list)
		if #list > 0 then
			if not table.find(list, Options.TeleportPlayerList.Value) then
				Options.TeleportPlayerList:SetValue(list[1])
			end
		else
			Options.TeleportPlayerList:SetValue("")
		end
	end)
end

track("TeleportPlayerAdded", Players.PlayerAdded:Connect(updateTeleportPlayerList))
track("TeleportPlayerRemoving", Players.PlayerRemoving:Connect(updateTeleportPlayerList))
