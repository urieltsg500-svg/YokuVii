local function getToolSlot(priorityList)
	local backpack = LocalPlayer:FindFirstChild("Backpack")
	local character = LocalPlayer.Character
	if not backpack or not character then return nil end

	for _, wantedId in ipairs(priorityList) do
		for i = 1, 10 do
			local slotName = tostring(i)

			-- Check Backpack
			local tool = backpack:FindFirstChild(slotName)
			if tool and tool:FindFirstChild("toolModel") then
				local id = tool.toolModel:GetAttribute("itemId")
				if id == wantedId then
					return i
				end
			end

			-- Check Character (equipped tools)
			local equipped = character:FindFirstChild(slotName)
			if equipped and equipped:FindFirstChild("toolModel") then
				local id = equipped.toolModel:GetAttribute("itemId")
				if id == wantedId then
					return i
				end
			end
		end
	end

	return nil
end

local function getChopTargetPart(obj)
	if not obj then return nil end
	local primary = obj.PrimaryPart
	if primary and primary:IsA("BasePart") then
		return primary
	end
	local part = obj:FindFirstChildWhichIsA("BasePart")
	if part then
		return part
	end
	for _, desc in ipairs(obj:GetDescendants()) do
		if desc:IsA("BasePart") then
			return desc
		end
	end
	return nil
end

local function getFlatDistance(a, b)
	local delta = Vector3.new(a.X, 0, a.Z) - Vector3.new(b.X, 0, b.Z)
	return delta.Magnitude
end

